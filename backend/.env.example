DATABASE_URL=postgresql://nugaslagi:nugaslagi@localhost:5432/elearning_dosen
DB_POOL_MIN_SIZE=1
DB_POOL_MAX_SIZE=10
DB_COMMAND_TIMEOUT=60

# Hanya dipakai oleh scripts/migrate_mongodb_to_postgresql.py saat migrasi.
MONGO_URL=mongodb://localhost:27017
MONGO_DB_NAME=elearning_dosen
CORS_ORIGINS=http://localhost:3000,http://localhost:3010
APP_URL=http://localhost:3010

# SCI-ID / Keycloak OIDC. Development may use a public client with PKCE and
# an empty secret; production should use a confidential client.
OIDC_ENABLED=false
OIDC_DISCOVERY_URL=http://localhost:8081/realms/sci/.well-known/openid-configuration
OIDC_ISSUER=http://localhost:8081/realms/sci
OIDC_CLIENT_ID=nugaslagi-local
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URI=http://127.0.0.1:8000/api/auth/sso/callback
OIDC_FRONTEND_URL=http://127.0.0.1:3000
OIDC_SCOPES=openid profile email roles
OIDC_LOCAL_LOGIN_ENABLED=true

# Google Drive storage for uploaded files.
# Use a Google Cloud service account, share the provided Drive folder with
# the service account email, then fill one credential source below.
GOOGLE_DRIVE_ENABLED=true
GOOGLE_DRIVE_ROOT_FOLDER_ID=
GOOGLE_DRIVE_ROOT_FOLDER_NAME=E-Learning Dosen
GOOGLE_DRIVE_REQUIRE_UPLOAD=false
GOOGLE_DRIVE_CONFIG_KEY=
GOOGLE_DRIVE_CONFIG_KEY_FILE=/absolute/path/.drive_config.key
# Akun Google Workspace yang diimpersonasi service account untuk membuat ruang Google Meet.
# Service account harus mengaktifkan Domain-wide Delegation dan scope:
# https://www.googleapis.com/auth/meetings.space.created
GOOGLE_MEET_ENABLED=false
GOOGLE_WORKSPACE_DELEGATED_USER=

# Optional fallback if not configured from UI.
# Option A: absolute path to the service account JSON file.
GOOGLE_SERVICE_ACCOUNT_FILE=/absolute/path/service-account.json

# Option B: raw JSON content, useful in some deployment platforms.
GOOGLE_SERVICE_ACCOUNT_JSON=

# Option C: base64-encoded JSON content, safest for one-line env vars.
GOOGLE_SERVICE_ACCOUNT_JSON_B64=

# SMTP Email Configuration (for password reset and notifications).
# You can configure these here or via the admin Settings > Email page.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_USE_TLS=true
SMTP_FROM_NAME=E-Learning Dosen
SMTP_FROM_EMAIL=your-email@gmail.com
