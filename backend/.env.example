MONGO_URL=mongodb://localhost:27017
DB_NAME=elearning_dosen
CORS_ORIGINS=http://localhost:3000,http://localhost:3010
APP_URL=http://localhost:3010

# Google Drive storage for uploaded files.
# Use a Google Cloud service account, share the provided Drive folder with
# the service account email, then fill one credential source below.
GOOGLE_DRIVE_ENABLED=true
GOOGLE_DRIVE_ROOT_FOLDER_ID=
GOOGLE_DRIVE_ROOT_FOLDER_NAME=E-Learning Dosen
GOOGLE_DRIVE_REQUIRE_UPLOAD=false
GOOGLE_DRIVE_CONFIG_KEY=
GOOGLE_DRIVE_CONFIG_KEY_FILE=/absolute/path/.drive_config.key

# Optional fallback if not configured from UI.
# Option A: absolute path to the service account JSON file.
GOOGLE_SERVICE_ACCOUNT_FILE=/absolute/path/service-account.json

# Option B: raw JSON content, useful in some deployment platforms.
GOOGLE_SERVICE_ACCOUNT_JSON=

# Option C: base64-encoded JSON content, safest for one-line env vars.
GOOGLE_SERVICE_ACCOUNT_JSON_B64=

# SMTP Email Configuration (for password reset and notifications).
# You can configure these here or via the admin Settings > Email page.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_USE_TLS=true
SMTP_FROM_NAME=E-Learning Dosen
SMTP_FROM_EMAIL=your-email@gmail.com
